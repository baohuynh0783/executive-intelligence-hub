# ====== BẮT BUỘC cho chế độ LIVE (phân tích công ty lạ tại event) ======
# Gemini API key — lấy từ Google AI Studio: https://aistudio.google.com/apikey
# Không có key, app vẫn chạy cho các prospect đã pre-bake (curated).
GEMINI_API_KEY=

# Tên model Gemini. Vào AI Studio xem model hiện hành rồi điền.
GEMINI_MODEL=gemini-2.5-flash

# ====== TUỲ CHỌN ======
# Live lỗi → tự rơi về kết quả pre-baked để demo không sập (true/false)
FALLBACK_TO_DEMO=true
FALLBACK_PROSPECT_ID=daiviet
